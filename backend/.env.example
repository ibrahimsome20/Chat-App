# ===========================================
#  Backend Environment Variables (example)
#  Copy this file to ".env" and fill in real values.
#  Never commit the real .env file.
# ===========================================

# --- Server ---
# Port the Express server listens on.
# NOTE: the frontend (frontend/src/api/axios.js) expects the API at
# http://localhost:5000, so keep this at 5000 for local development.
PORT_Server=5000

# Environment mode: "development" or "production".
# In production, auth cookies are sent with Secure + SameSite=None.
NODE_ENV=development

# URL of the frontend app, used for the CORS allow-origin.
# Vite's default dev server runs on port 5173.
CLIENT_URL=http://localhost:5173

# --- Database ---
# MongoDB connection string.
# Local example:  mongodb://127.0.0.1:27017/chat-app
# Atlas example:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chat-app
DB_URI=mongodb://127.0.0.1:27017/chat-app

# --- Authentication ---
# Secret used to sign JWT auth tokens. Use a long, random string.
# Generate one with: openssl rand -hex 32
SECRET=replace_with_a_long_random_secret

# --- Cloudinary (image / avatar uploads) ---
# From your Cloudinary dashboard: https://console.cloudinary.com/
CLOUD_NAME=your_cloudinary_cloud_name
# NOTE: despite the name, CLOUD_API_NAME maps to the Cloudinary API KEY.
CLOUD_API_NAME=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# --- Sentry (error monitoring) ---
# Leave empty to disable Sentry. Get the DSN from your Sentry project settings.
SENTRY_DSN=
# Portion of transactions traced for performance monitoring (0.0 - 1.0).
SENTRY_TRACES_SAMPLE_RATE=0.1
